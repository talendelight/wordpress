  "gitCommits": [],
  "deploymentSteps": [
    {
      "step": 1,
      "description": "Backup production",
      "command": "powershell -File infra/shared/scripts/wp-action.ps1 backup",
      "critical": true
    },
    {
      "step": 2,
      "description": "Deploy code to main branch",
      "command": "git checkout main && git merge develop --no-edit && git push origin main",
      "critical": true
    },
    {
      "step": 3,
      "description": "Wait for Hostinger auto-deployment",
      "command": "Start-Sleep -Seconds 30",
      "critical": true
    },
    {
      "step": 4,
      "description": "Verify deployment (post-deployment check)",
      "command": "powershell -File infra/shared/scripts/wp-action.ps1 verify-deployment",
      "critical": true,
      "notes": "NEW in v3.6.4: Mandatory verification to detect deployment failures"
    },
    {
      "step": 5,
      "description": "Deploy database migration (SQL files)",
      "command": "scp SQL files to production, import via phpMyAdmin or wp-cli",
      "critical": true,
      "notes": "Apply PENG-015 SQL migration for td_registration_request CPT"
    },
    {
      "step": 6,
      "description": "Deploy Privacy Policy and Terms & Conditions pages",
      "command": "Manual page deployment via restore-page-X.php script",
      "critical": true,
      "notes": "Deploy both pages using POST-DEPLOYMENT-CHECKLIST.md workflow. Privacy Policy (page 3), Terms & Conditions (page 60)"
    },
    {
      "step": 7,
      "description": "Deploy HireAccord branding (logo, favicon, site title)",
      "command": "scp logo and favicon to production uploads/2026/, import with wp media import, set custom_logo and site_icon, update blogname",
      "critical": true,
      "notes": "1. scp HireAccord-logo-blue-big.png and apple-touch-icon.png to production:/uploads/2026/ 2. wp media import (get IDs) 3. wp theme mod set custom_logo [ID] 4. wp option update site_icon [ID] 5. wp option update blogname 'HireAccord' 6. See infra/shared/db/260308-1500-rebrand-hireaccord.sql for reference"
    },
    {
      "step": 8,
      "description": "Clear production cache",
      "command": "ssh production 'cd public_html && wp cache flush --allow-root'",
      "critical": false
    },
    {
      "step": 9,
      "description": "Run health check",
      "command": "powershell -File infra/shared/scripts/wp-action.ps1 verify",
      "critical": true
    },
    {
      "step": 10,
      "description": "Functional testing",
      "command": "User tests Privacy Policy page, Record ID generation, CPT creation",
      "critical": true
    }
  ],
  "verificationChecklist": [
    "Site title displays 'HireAccord' (not 'TalenDelight')",
